# .env.example

# ASR
DEEPGRAM_API_KEY=
FILTER_SELF_SPEAKER=true
MIC_SAMPLE_RATE=16000
NOISE_SUPPRESSION=rnnoise

# Integrations
ZERO_CRM_API_KEY=
ZERO_CRM_BASE_URL=https://api.zero.inc/v1
UNIFY_GTM_API_KEY=
UNIFY_GTM_BASE_URL=https://api.unifygtm.com/v1
CURSOR_SDK_API_KEY=

# Google MCP (Gmail + Google Docs + Google Calendar)
# OAuth token for getwarmth@gmail.com — NOT the GCP service account.
# Run: python scripts/setup_gmail_oauth.py  (see docs/GMAIL_MCP.md)
GOOGLE_MCP_CREDENTIALS=google-gmail-oauth.json
GOOGLE_MCP_SERVER_URL=http://localhost:3000
GOOGLE_MCP_PORT=3000

# Lightfern (outreach personalization + follow-up workflows)
LIGHTFERN_WEBHOOK_URL=

# Warmth Gmail client — drafts open here for Lightfern to polish
WARMTH_CLIENT_EMAIL=getwarmth@gmail.com
WARMTH_CLIENT_NAME=Warmth

# Web dashboard (comma-separated allowed CORS origins for the FastAPI backend)
WEB_ALLOWED_ORIGINS=http://localhost:5173

# Signal Sources
TAVILY_API_KEY= 

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_DATABASE_URL=

# API hardening (production Cloud Run — see infra/cloudrun-env.yaml)
REQUIRE_FIREBASE_AUTH=false
SIGNAL_RATE_LIMIT_ENABLED=true
SIGNAL_RATE_LIMIT_IP_PER_MINUTE=30
SIGNAL_RATE_LIMIT_TOKEN_PER_MINUTE=60

# GCP
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=
GCP_REGION=us-central1
PUBSUB_TOPIC=signal-events

# Community
COMMUNITY_GROUPS_ENABLED=true
COMMUNITY_PERMISSIONS=default

# User Configuration
USER_ROLE=individual
TEAM_SIZE=1
COMPANY_STAGE=early

# ML
HF_MODEL_PATH=models/icp-classifier-v1