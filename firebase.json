{
  "hosting": {
    "public": "web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://warmth-api-30164818817.us-central1.run.app https://*.googleapis.com https://*.firebaseio.com https://*.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "auth": {
    "authorizedDomains": [
      "localhost",
      "warmth-gtm-hackathon.web.app",
      "warmth-gtm-hackathon.firebaseapp.com"
    ],
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "Warmth",
        "supportEmail": "dzakwan1844@gmail.com"
      }
    }
  }
}
