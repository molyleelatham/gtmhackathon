{
  "hosting": {
    "public": "web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "auth": {
    "authorizedDomains": [
      "localhost",
      "warmth-gtm-hackathon.web.app",
      "warmth-gtm-hackathon.firebaseapp.com"
    ],
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "Warmth",
        "supportEmail": "dzakwan1844@gmail.com"
      }
    }
  }
}
