rules_version = '2';

// Public read for marketing assets under landing/; writes require auth.
service firebase.storage {
  match /b/{bucket}/o {
    match /landing/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
