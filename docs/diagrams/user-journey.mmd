        A2 --> A3
        A2 --> A4
    end

    subgraph desk["Back at hotel / desk"]
        D1["Review connections on web"]
        D2["Lightfern polishes draft in Gmail"]
        D3["Human approves and sends"]
        D1 --> D2 --> D3
    end

    before --> floor --> after --> desk

